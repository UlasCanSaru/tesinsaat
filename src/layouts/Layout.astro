---
import '../styles/global.css';
// Layout.astro — Tüm sayfaları saran ana iskelet
// Her sayfada <head>, fontlar, navbar ve footer ortak olacak

// Props: Her sayfa kendi title ve description'ını gönderir

const {
  title = "TES İnşaat | İstanbul İnşaat Firması",
  description = "2001'den beri İstanbul ve Marmara Bölgesi'nde kamu ve özel sektör projelerinde uzman inşaat firması. Alçı, sıva, boya, izolasyon, anahtar teslim villa.",
} = Astro.props;

// Mevcut sayfa URL'i (aktif menü için)
const currentPath = Astro.url.pathname;
---


<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Self-hosted fonts -->
  <link rel="preload" href="/fonts/outfit-400-700-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-display-700-800-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-400-latin-ext.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Sayfa başlığı -->
  <title>{title}</title>
</head>

<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="section-container">
      <div class="navbar-inner">
        <!-- Logo -->
        <a href="/" class="navbar-logo">
          <span class="logo-main">TES</span>
          <span class="logo-sub">İNŞAAT</span>
        </a>

        <!-- Masaüstü Menü -->
        <div class="navbar-links">
          <a href="/hakkimizda" class:list={[currentPath === '/hakkimizda/' && 'active']}>
            Hakkımızda
          </a>
          <a href="/hizmetler" class:list={[currentPath.startsWith('/hizmetler') && 'active']}>
            Hizmetler
          </a>
          <a href="/projeler" class:list={[currentPath.startsWith('/projeler') && 'active']}>
            Projeler
          </a>
          <a href="/blog" class:list={[currentPath.startsWith('/blog') && 'active']}>
            Blog
          </a>
          <a href="/iletisim" class="navbar-cta">
            İletişim
          </a>
        </div>

        <!-- Mobil Menü Butonu -->
        <button class="navbar-toggle" id="menuToggle" aria-label="Menüyü aç">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <!-- Mobil Menü -->
    <div class="navbar-mobile" id="mobileMenu">
      <a href="/hakkimizda">Hakkımızda</a>
      <a href="/hizmetler">Hizmetler</a>
      <a href="/projeler">Projeler</a>
      <a href="/blog">Blog</a>
      <a href="/iletisim">İletişim</a>
    </div>
  </nav>

  <!-- Sayfa İçeriği (her sayfadan buraya gelir) -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="section-container">
      <div class="footer-grid">
        <!-- Firma bilgisi -->
        <div class="footer-col">
          <a href="/" class="footer-logo">
            <span class="logo-main">TES</span>
            <span class="logo-sub">İNŞAAT</span>
          </a>
          <p class="footer-desc">
            2001'den beri İstanbul ve Marmara Bölgesi'nde kamu ve özel sektör projelerinde güvenilir çözüm ortağı.
          </p>
        </div>

        <!-- Sayfa linkleri -->
        <div class="footer-col">
          <h4 class="footer-heading">Sayfalar</h4>
          <a href="/hakkimizda">Hakkımızda</a>
          <a href="/hizmetler">Hizmetler</a>
          <a href="/projeler">Projeler</a>
          <a href="/blog">Blog</a>
          <a href="/iletisim">İletişim</a>
        </div>

        <!-- Yasal -->
        <div class="footer-col">
          <h4 class="footer-heading">Yasal</h4>
          <a href="/gizlilik-politikasi">Gizlilik Politikası</a>
          <a href="/kvkk">KVKK Aydınlatma</a>
          <a href="/cerez-politikasi">Çerez Politikası</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; 2025 TES İnşaat. Tüm hakları saklıdır.</p>
      </div>
    </div>
  </footer>

  <!-- WhatsApp Floating Buton -->
  <a
    href="https://wa.me/905XXXXXXXXX?text=Merhaba%2C%20bilgi%20almak%20istiyorum"
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="WhatsApp ile iletişime geçin"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Scroll Animasyonu Script -->
  <script>
    // fade-in class'ına sahip elementleri ekrana girdikçe görünür yap
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

    // Mobil menü toggle
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');

    menuToggle?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('open');
      menuToggle.classList.toggle('open');
    });
  </script>
</body>
</html>

<style>
  /* ============================================
     Navbar
     ============================================ */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--cream);
    border-bottom: 1px solid var(--sand);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .navbar-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1;
  }

  .navbar-logo .logo-main {
    font-family: 'Playfair Display', serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--deep-charcoal);
    letter-spacing: 3px;
  }

  .navbar-logo .logo-sub {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    color: var(--copper);
    letter-spacing: 6px;
    text-transform: uppercase;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar-links a {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--warm-gray);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .navbar-links a:hover,
  .navbar-links a.active {
    color: var(--deep-charcoal);
  }

  .navbar-cta {
    color: var(--copper) !important;
    font-weight: 500 !important;
  }

  .navbar-cta:hover {
    color: var(--copper-dark) !important;
  }

  /* Mobil menü butonu */
  .navbar-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .navbar-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--deep-charcoal);
    transition: all 0.3s ease;
  }

  .navbar-toggle.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .navbar-toggle.open span:nth-child(2) {
    opacity: 0;
  }
  .navbar-toggle.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobil menü panel */
  .navbar-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.25rem 1.5rem;
    border-top: 1px solid var(--sand);
  }

  .navbar-mobile.open {
    display: flex;
  }

  .navbar-mobile a {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    color: var(--deep-charcoal);
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--sand);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar-links {
      display: none;
    }
    .navbar-toggle {
      display: flex;
    }
  }

  /* ============================================
     Footer
     ============================================ */
  .site-footer {
    background-color: var(--deep-charcoal);
    color: rgba(250, 246, 241, 0.5);
    padding-top: 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .footer-logo .logo-main {
    font-family: 'Playfair Display', serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--cream);
    letter-spacing: 3px;
  }

  .footer-logo .logo-sub {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.55rem;
    color: var(--copper);
    letter-spacing: 5px;
    text-transform: uppercase;
  }

  .footer-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(250, 246, 241, 0.4);
  }

  .footer-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(250, 246, 241, 0.6);
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    font-size: 0.85rem;
    color: rgba(250, 246, 241, 0.4);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--copper-light);
  }

  .footer-bottom {
    border-top: 1px solid rgba(250, 246, 241, 0.08);
    padding: 1.25rem 0;
    text-align: center;
    font-size: 0.75rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* ============================================
     WhatsApp Floating Buton
     ============================================ */
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 40;
    width: 56px;
    height: 56px;
    background-color: var(--whatsapp);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .whatsapp-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
  }
</style>
