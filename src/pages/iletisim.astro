---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="İletişim | TES İnşaat — Bize Ulaşın"
  description="TES İnşaat ile iletişime geçin. WhatsApp, telefon, e-posta ve adres bilgilerimiz. Ücretsiz keşif ve fiyat teklifi için hemen arayın."
>

  <!-- Hero -->
  <section class="contact-hero">
    <div class="section-container" style="text-align: center;">
      <p class="accent-text fade-in" style="color: var(--warm-gray);">Bize ulaşın</p>
      <h1 class="fade-in fade-in-delay-1">Projenizi birlikte<br>hayata geçirelim.</h1>
      <p class="contact-hero-desc fade-in fade-in-delay-2">
        Ücretsiz keşif, fiyat teklifi veya sorularınız için
        WhatsApp üzerinden hemen ulaşabilirsiniz.
      </p>
      <a
        href="https://wa.me/905XXXXXXXXX?text=Merhaba%2C%20bilgi%20almak%20istiyorum"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp btn-whatsapp-lg fade-in fade-in-delay-3"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp ile Yazın
      </a>
      <p class="contact-hero-sub fade-in fade-in-delay-3">Genellikle 1 saat içinde yanıt veriyoruz</p>
    </div>
  </section>

  <!-- İletişim bilgileri -->
  <section class="section-padding" style="background-color: var(--cream);">
    <div class="section-container">
      <p class="accent-text fade-in">İletişim bilgileri</p>
      <h2 class="section-title fade-in">Bize nasıl ulaşabilirsiniz?</h2>
      <div class="contact-grid">
        <div class="contact-card fade-in">
          <div class="contact-icon">T</div>
          <div>
            <h4>Telefon</h4>
            <p>Hafta içi 09:00–18:00 arası</p>
            <a href="tel:+905323330777">+90 532 333 07 77</a>
          </div>
        </div>
        <div class="contact-card fade-in">
          <div class="contact-icon">@</div>
          <div>
            <h4>E-posta</h4>
            <p>Genel bilgi ve teklif talepleri</p>
            <a href="mailto:info@tesinsaat.com">info@tesinsaat.com</a>
          </div>
        </div>
        <div class="contact-card contact-card-full fade-in">
          <div class="contact-icon">A</div>
          <div>
            <h4>Adres</h4>
            <p>TES İnşaat Merkez Ofis<br>İstanbul, Türkiye</p>
            <a href="#" target="_blank" rel="noopener noreferrer">Yol tarifi al &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Harita -->
<section class="section-padding" style="background-color: var(--sand);">
  <div class="section-container">
    <p class="accent-text fade-in">Konum</p>
    <h2 class="section-title fade-in">Ofis konumumuz</h2>

    <div class="map-container fade-in">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d753.7121051259028!2d29.15541970176902!3d40.9190693263914!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cac411867ad693%3A0xeaa1f2647664aca8!2sCevizli%2C%20Zuhal%20Cd.%2036A%2C%2034846%20Maltepe%2F%C4%B0stanbul!5e0!3m2!1str!2str!4v1774321070275!5m2!1str!2str"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>

  </div>
</section>

  <!-- Çalışma saatleri -->
  <section class="section-padding" style="background-color: var(--cream);">
    <div class="section-container">
      <p class="accent-text fade-in">Çalışma saatleri</p>
      <h2 class="section-title fade-in">Ne zaman ulaşabilirsiniz?</h2>
      <div class="hours-grid">
        <div class="hour-row fade-in"><span class="day">Pazartesi</span><span class="time">09:00 – 18:00</span></div>
        <div class="hour-row fade-in"><span class="day">Salı</span><span class="time">09:00 – 18:00</span></div>
        <div class="hour-row fade-in"><span class="day">Çarşamba</span><span class="time">09:00 – 18:00</span></div>
        <div class="hour-row fade-in"><span class="day">Perşembe</span><span class="time">09:00 – 18:00</span></div>
        <div class="hour-row fade-in"><span class="day">Cuma</span><span class="time">09:00 – 18:00</span></div>
        <div class="hour-row fade-in"><span class="day">Cumartesi</span><span class="time">10:00 – 14:00</span></div>
        <div class="hour-row fade-in"><span class="day">Pazar</span><span class="time closed">Kapalı</span></div>
        <div class="hour-row hour-wp fade-in"><span class="day">WhatsApp</span><span class="time">7/24</span></div>
      </div>
    </div>
  </section>

  <!-- Hızlı erişim -->
  <section class="section-padding" style="background-color: var(--sand);">
    <div class="section-container">
      <p class="accent-text fade-in">Hızlı erişim</p>
      <h2 class="section-title fade-in">Ne arıyorsunuz?</h2>
      <div class="quick-grid">
        <a href="https://wa.me/905323330777" target="_blank" rel="noopener noreferrer" class="quick-card fade-in">
          <span class="quick-num">01</span>
          <h4>Teklif almak</h4>
          <p>Projeniz için ücretsiz keşif ve fiyat teklifi.</p>
          <span class="quick-link">WhatsApp &rarr;</span>
        </a>
        <a href="/hizmetler" class="quick-card fade-in">
          <span class="quick-num">02</span>
          <h4>Hizmetleri incele</h4>
          <p>9 farklı hizmet alanımızı keşfedin.</p>
          <span class="quick-link">Hizmetler &rarr;</span>
        </a>
        <a href="/projeler" class="quick-card fade-in">
          <span class="quick-num">03</span>
          <h4>Referanslar</h4>
          <p>Tamamlanan projelerimize göz atın.</p>
          <span class="quick-link">Projeler &rarr;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero { background-color: var(--deep-charcoal); padding: 5rem 0 4rem; }
  .contact-hero h1 { font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 800; color: var(--cream); margin: 0.5rem 0 1rem; }
  .contact-hero-desc { font-size: 1rem; color: rgba(250,246,241,0.6); max-width: 400px; margin: 0 auto 1.5rem; line-height: 1.7; }
  .btn-whatsapp-lg { padding: 1rem 2rem; font-size: 1rem; }
  .contact-hero-sub { font-size: 0.8rem; color: rgba(250,246,241,0.4); margin-top: 0.75rem; }

  .section-title { font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; color: var(--deep-charcoal); margin-bottom: 1.5rem; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-card {
    display: flex; gap: 1rem; align-items: flex-start;
    background-color: white; border: 1px solid var(--sand); border-radius: 12px; padding: 1.5rem;
  }
  .contact-card-full { grid-column: span 2; }
  .contact-icon {
    width: 44px; height: 44px; background-color: var(--cream); border-radius: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    font-size: 1rem; color: var(--copper); font-weight: 700;
  }
  .contact-card h4 { font-family: 'Outfit', sans-serif; font-size: 0.9rem; font-weight: 600; color: var(--deep-charcoal); margin-bottom: 0.2rem; }
  .contact-card p { font-size: 0.8rem; color: var(--warm-gray); line-height: 1.5; }
  .contact-card a { font-size: 0.85rem; color: var(--copper); font-weight: 500; text-decoration: none; }
  .contact-card a:hover { color: var(--copper-dark); }

  .map-placeholder {
    height: 240px; background-color: white; border-radius: 12px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    border: 1px solid var(--sand); text-align: center;
  }
  .map-pin {
    width: 40px; height: 40px; background-color: var(--copper); color: var(--cream);
    border-radius: 50% 50% 50% 0; transform: rotate(-45deg); display: flex;
    align-items: center; justify-content: center; font-weight: 700; margin-bottom: 0.75rem;
  }
  .map-pin span { transform: rotate(45deg); }
  .map-placeholder p { font-size: 0.9rem; color: var(--warm-gray); }
  .map-placeholder span { font-size: 0.75rem; color: var(--warm-gray); opacity: 0.6; margin-top: 0.25rem; }

  .hours-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; max-width: 480px; }
  .hour-row {
    display: flex; justify-content: space-between; padding: 0.75rem 1rem;
    background-color: white; border-radius: 8px;
  }
  .day { font-size: 0.85rem; font-weight: 500; color: var(--deep-charcoal); }
  .time { font-size: 0.85rem; color: var(--warm-gray); }
  .time.closed { color: var(--burnt-orange); font-weight: 500; }
  .hour-wp {
    background-color: var(--cream); border: 1px solid rgba(184,115,51,0.2);
  }
  .hour-wp .day { color: var(--copper); }
  .hour-wp .time { color: var(--copper); font-weight: 500; }

  .quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .quick-card {
    background-color: white; border: 1px solid var(--sand); border-radius: 12px;
    padding: 1.5rem; text-decoration: none; text-align: center;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .quick-card:hover { border-color: var(--copper); transform: translateY(-2px); }
  .quick-num { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 800; color: var(--sand); display: block; margin-bottom: 0.5rem; }
  .quick-card h4 { font-family: 'Outfit', sans-serif; font-size: 0.9rem; font-weight: 600; color: var(--deep-charcoal); margin-bottom: 0.25rem; }
  .quick-card p { font-size: 0.8rem; color: var(--warm-gray); line-height: 1.4; margin-bottom: 0.5rem; }
  .quick-link { font-size: 0.8rem; color: var(--copper); font-weight: 500; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-card-full { grid-column: span 1; }
    .hours-grid { grid-template-columns: 1fr; }
    .quick-grid { grid-template-columns: 1fr; }
  }
	.map-container {
  width: 100%;
  height: 400px;
  border-radius: 12px;
  overflow: hidden;
}

.map-container iframe {
  width: 100%;
  height: 100%;
  border: 0;
  filter: grayscale(100%);
  transition: 0.3s ease;
}

.map-container iframe:hover {
  filter: grayscale(0%);
}
</style>
