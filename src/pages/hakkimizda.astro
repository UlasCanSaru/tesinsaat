---
import Layout from '../layouts/Layout.astro';

const tarihce = [
  { yil: "2001", baslik: "Kuruluş", aciklama: "TES İnşaat İstanbul'da kuruldu. İlk projeler kamu sektöründe alçı ve sıva işleri." },
  { yil: "2006 – 2013", baslik: "Kamu projeleri", aciklama: "MSB askeri tesis ve Sağlık Bakanlığı hastane projeleri. Kamu referansları güçlendi." },
  { yil: "2014 – 2020", baslik: "Büyük ölçek", aciklama: "Türk Telekom kurum binaları, Tepe İnşaat AVM projeleri, Garanti Koza ve Çukurova Baytur ile büyük ölçekli işler." },
  { yil: "2020 – Günümüz", baslik: "Genişleme", aciklama: "Anahtar teslim villa projeleri, metro istasyonu ince işleri ve genişleyen hizmet yelpazesi." },
];

const degerler = [
  { no: "01", baslik: "Kalite", aciklama: "Her projede yüksek işçilik standartları ve malzeme kalitesi." },
  { no: "02", baslik: "Güvenilirlik", aciklama: "Kamu kurumları ve büyük firmaların tercih ettiği iş ortağı." },
  { no: "03", baslik: "Deneyim", aciklama: "24 yılı aşkın sektör tecrübesi ile her ölçekte proje yönetimi." },
  { no: "04", baslik: "Çözüm Odaklılık", aciklama: "Projeye özel yaklaşım, esnek çözümler ve zamanında teslimat." },
];

const referanslar = [
  { isim: "MSB", aciklama: "Askeri tesis inşaatları" },
  { isim: "Sağlık Bakanlığı", aciklama: "Hastane projeleri" },
  { isim: "Türk Telekom", aciklama: "Kurum binaları" },
  { isim: "Tepe İnşaat", aciklama: "AVM projeleri" },
  { isim: "Garanti Koza", aciklama: "İnce işler" },
  { isim: "Çukurova Baytur", aciklama: "Konut projeleri" },
];

const istatistikler = [
  { rakam: "24+", etiket: "Yıl deneyim" },
  { rakam: "50+", etiket: "Tamamlanan proje" },
  { rakam: "11+", etiket: "Kurumsal referans" },
  { rakam: "9", etiket: "Hizmet alanı" },
];
---

<Layout
  title="Hakkımızda | TES İnşaat — 2001'den Beri İstanbul"
  description="TES İnşaat'ın hikayesi, değerleri ve referansları. 2001'den beri İstanbul ve Marmara Bölgesi'nde kamu ve özel sektör projelerinde güvenilir çözüm ortağı."
>

  <!-- HERO -->
  <section class="about-hero">
    <div class="section-container about-hero-inner">
      <div class="about-hero-text">
        <p class="accent-text fade-in">Bizi tanıyın</p>
        <h1 class="fade-in fade-in-delay-1">2001'den beri<br>inşaatın güvenilir ismi.</h1>
        <p class="about-hero-desc fade-in fade-in-delay-2">
          İstanbul ve Marmara Bölgesi genelinde AVM, okul, hastane, askeri tesis
          ve konut projelerinde uzmanlaşmış bir inşaat firmasıyız.
        </p>
      </div>
      <div class="about-hero-img fade-in fade-in-delay-3">
        <span>Ekip / şantiye fotoğrafı</span>
      </div>
    </div>
  </section>

  <!-- TARİHÇE -->
  <section class="section-padding" style="background-color: var(--cream);">
    <div class="section-container">
      <p class="accent-text fade-in">Hikayemiz</p>
      <h2 class="section-title fade-in">Firma tarihçesi</h2>
      <div class="timeline">
        {tarihce.map((t, i) => (
          <div class="tl-item fade-in" style={`transition-delay: ${i * 0.1}s`}>
            <div class="tl-dot"></div>
            <div class="tl-content">
              <span class="tl-year">{t.yil}</span>
              <p class="tl-text">{t.aciklama}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- İSTATİSTİKLER -->
  <section class="section-padding" style="background-color: var(--sand);">
    <div class="section-container">
      <p class="accent-text fade-in">Rakamlarla</p>
      <h2 class="section-title fade-in">TES İnşaat</h2>
      <div class="stats-grid">
        {istatistikler.map((s) => (
          <div class="stat-card fade-in">
            <span class="stat-number">{s.rakam}</span>
            <span class="stat-label">{s.etiket}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DEĞERLER -->
  <section class="section-padding" style="background-color: var(--cream);">
    <div class="section-container">
      <p class="accent-text fade-in">Değerlerimiz</p>
      <h2 class="section-title fade-in">Neden TES İnşaat?</h2>
      <div class="values-grid">
        {degerler.map((d) => (
          <div class="value-card fade-in">
            <div class="value-icon"><span>{d.no}</span></div>
            <h3>{d.baslik}</h3>
            <p>{d.aciklama}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REFERANSLAR -->
  <section class="section-padding" style="background-color: var(--sand);">
    <div class="section-container">
      <p class="accent-text fade-in">İş ortaklarımız</p>
      <h2 class="section-title fade-in">Referanslarımız</h2>
      <div class="ref-grid">
        {referanslar.map((r) => (
          <div class="ref-card fade-in">
            <span class="ref-name">{r.isim}</span>
            <span class="ref-desc">{r.aciklama}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color: var(--cream); padding: 2rem 0 4rem;">
    <div class="section-container">
      <div class="cta-inner fade-in">
        <div class="cta-text">
          <h2>Projeniz için görüşelim</h2>
          <p>Ücretsiz keşif ve fiyat teklifi alın.</p>
        </div>
        <a href="https://wa.me/905XXXXXXXXX?text=Merhaba%2C%20teklif%20almak%20istiyorum" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          WhatsApp ile Ulaşın <span>&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .about-hero {
    background-color: var(--deep-charcoal);
    padding: 5rem 0 4rem;
  }
  .about-hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  .about-hero-text { flex: 1; }
  .about-hero-text h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--cream);
    margin: 0.5rem 0 1rem;
  }
  .about-hero-desc {
    font-size: 1rem;
    color: rgba(250,246,241,0.6);
    line-height: 1.7;
    max-width: 460px;
  }
  .about-hero-img {
    width: 280px;
    height: 240px;
    background-color: var(--earth-brown);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .about-hero-img span {
    font-size: 0.85rem;
    color: rgba(250,246,241,0.4);
    font-style: italic;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--deep-charcoal);
    margin-bottom: 2rem;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background-color: var(--sand);
  }
  .tl-item {
    position: relative;
    margin-bottom: 2rem;
  }
  .tl-item:last-child { margin-bottom: 0; }
  .tl-dot {
    position: absolute;
    left: -2rem;
    top: 4px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: var(--copper);
    border: 3px solid var(--cream);
  }
  .tl-year {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--copper);
    display: block;
    margin-bottom: 0.25rem;
  }
  .tl-text {
    font-size: 0.9rem;
    color: var(--earth-brown);
    line-height: 1.6;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .stat-card {
    text-align: center;
    padding: 1.5rem 1rem;
    background-color: white;
    border-radius: 12px;
  }
  .stat-number {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--copper);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--warm-gray);
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .value-card {
    background-color: white;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid var(--sand);
  }
  .value-icon {
    width: 40px;
    height: 40px;
    background-color: var(--cream);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }
  .value-icon span {
    font-size: 0.8rem;
    color: var(--copper);
    font-weight: 600;
  }
  .value-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--deep-charcoal);
    margin-bottom: 0.375rem;
  }
  .value-card p {
    font-size: 0.85rem;
    color: var(--warm-gray);
    line-height: 1.5;
  }

  /* References */
  .ref-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .ref-card {
    background-color: white;
    border: 1px solid var(--sand);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
  }
  .ref-name {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--deep-charcoal);
    margin-bottom: 0.25rem;
  }
  .ref-desc {
    font-size: 0.8rem;
    color: var(--warm-gray);
  }

  /* CTA */
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--sand);
    border-radius: 16px;
    padding: 2.5rem;
  }
  .cta-text h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--deep-charcoal);
    margin-bottom: 0.25rem;
  }
  .cta-text p {
    font-size: 0.9rem;
    color: var(--warm-gray);
  }

  @media (max-width: 768px) {
    .about-hero-inner { flex-direction: column; }
    .about-hero-img { width: 100%; height: 200px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .values-grid { grid-template-columns: 1fr; }
    .ref-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-inner { flex-direction: column; text-align: center; gap: 1.5rem; padding: 2rem 1.5rem; }
  }
</style>
