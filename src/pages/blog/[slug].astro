---
import Layout from '../../layouts/Layout.astro';

export const yazilar: Record<string, any> = {
  "anahtar-teslim-villa-rehberi": {
    baslik: "Anahtar teslim villa yaptırırken dikkat edilmesi gereken 10 konu",
    tarih: "15 Mart 2026",
    sure: "8 dk okuma",
    kategori: "Rehber",
    ilgiliHizmet: { baslik: "Anahtar teslim villa hizmeti", slug: "anahtar-teslim-villa" },
  },
  "boya-secimi-rehberi": {
    baslik: "İç ve dış cephe boya seçimi: nelere dikkat etmeli?",
    tarih: "10 Mart 2026",
    sure: "5 dk okuma",
    kategori: "Rehber",
    ilgiliHizmet: { baslik: "Boya işleri hizmeti", slug: "boya-isleri" },
  },
  "insaat-maliyetleri-2026": {
    baslik: "2026'da inşaat maliyetleri: güncel durum ve öngörüler",
    tarih: "5 Mart 2026",
    sure: "6 dk okuma",
    kategori: "Sektör",
    ilgiliHizmet: null,
  },
  "sile-villa-hikayesi": {
    baslik: "Şile villa projesi: baştan sona tüm süreç",
    tarih: "28 Şubat 2026",
    sure: "10 dk okuma",
    kategori: "Proje hikayesi",
    ilgiliHizmet: { baslik: "Anahtar teslim villa hizmeti", slug: "anahtar-teslim-villa" },
  },
  "su-izolasyonu-onemi": {
    baslik: "Su izolasyonu neden bu kadar önemli?",
    tarih: "20 Şubat 2026",
    sure: "4 dk okuma",
    kategori: "Rehber",
    ilgiliHizmet: { baslik: "İzolasyon hizmeti", slug: "izolasyon" },
  },
};

export function getStaticPaths() {
  return Object.keys(yazilar).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const yazi = yazilar[slug as string];
if (!yazi) Astro.redirect('/blog');
---

<Layout title={`${yazi.baslik} | TES İnşaat Blog`} description={yazi.baslik}>

  <div class="breadcrumb-bar">
    <div class="section-container">
      <a href="/">Ana Sayfa</a><span class="sep">/</span>
      <a href="/blog">Blog</a><span class="sep">/</span>
      <span class="current">{yazi.baslik}</span>
    </div>
  </div>

  <div class="article-hero"></div>

  <article class="article-wrap">
    <span class="article-tag">{yazi.kategori}</span>
    <h1>{yazi.baslik}</h1>

    <div class="article-meta">
      <div class="author-avatar">TI</div>
      <div>
        <span class="author-name">TES İnşaat</span>
        <span class="meta-detail">{yazi.tarih}  ·  {yazi.sure}</span>
      </div>
    </div>

    <div class="article-body">
      <p>Bu blog yazısı henüz hazırlanmaktadır. İçerik eklendiğinde burada görünecektir.</p>
      <p>Blog yazıları Markdown (.md) dosyası olarak <code>src/content/blog/</code> klasörüne eklenecek ve otomatik olarak bu şablona yerleşecektir.</p>
    </div>

    {yazi.ilgiliHizmet && (
      <div class="service-link-box">
        <div>
          <h4>{yazi.ilgiliHizmet.baslik}</h4>
          <p>Projeden teslime tüm sürecin tek elden yönetimi.</p>
        </div>
        <a href={`/hizmetler/${yazi.ilgiliHizmet.slug}`} class="btn-primary" style="font-size:0.8rem; padding:0.6rem 1.25rem;">
          Hizmeti İncele &rarr;
        </a>
      </div>
    )}
  </article>

  <section style="background-color: var(--cream); padding: 2rem 0 4rem;">
    <div class="section-container">
      <div class="cta-inner fade-in">
        <div class="cta-text">
          <h2>Projeniz için görüşelim</h2>
          <p>Ücretsiz keşif ve fiyat teklifi alın.</p>
        </div>
        <a href="https://wa.me/905XXXXXXXXX" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          WhatsApp ile Ulaşın <span>&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .breadcrumb-bar {
    background-color: var(--cream); padding: 0.75rem 0; font-size: 0.8rem; border-bottom: 1px solid var(--sand);
  }
  .breadcrumb-bar a { color: var(--warm-gray); text-decoration: none; }
  .breadcrumb-bar .sep { margin: 0 0.5rem; color: var(--copper-light); }
  .breadcrumb-bar .current { color: var(--deep-charcoal); font-weight: 500; }

  .article-hero {
    height: 280px;
    background: linear-gradient(135deg, var(--copper-light), var(--copper-dark));
  }

  .article-wrap {
    max-width: 640px; margin: -3rem auto 0; position: relative;
    background-color: var(--cream); border-radius: 16px 16px 0 0;
    padding: 2.5rem 2rem 3rem;
  }

  .article-tag {
    display: inline-block; padding: 3px 12px; border-radius: 20px;
    font-size: 0.75rem; font-weight: 500; margin-bottom: 0.75rem;
    background: rgba(59,139,212,0.12); color: #185FA5;
  }

  .article-wrap h1 {
    font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800;
    color: var(--deep-charcoal); line-height: 1.3; margin-bottom: 1.25rem;
  }

  .article-meta {
    display: flex; align-items: center; gap: 0.75rem;
    padding-bottom: 1.25rem; margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--sand);
  }
  .author-avatar {
    width: 40px; height: 40px; border-radius: 50%; background-color: var(--sand);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; color: var(--copper); font-weight: 600;
  }
  .author-name { display: block; font-size: 0.9rem; font-weight: 500; color: var(--deep-charcoal); }
  .meta-detail { font-size: 0.8rem; color: var(--warm-gray); }

  .article-body p {
    font-size: 0.95rem; color: var(--earth-brown); line-height: 1.8; margin-bottom: 1rem;
  }
  .article-body code {
    font-family: monospace; background-color: var(--sand); padding: 0.15rem 0.4rem;
    border-radius: 4px; font-size: 0.85rem;
  }

  .service-link-box {
    display: flex; align-items: center; justify-content: space-between;
    background-color: white; border: 1px solid var(--sand); border-radius: 12px;
    padding: 1.25rem; margin-top: 2rem;
  }
  .service-link-box h4 {
    font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700;
    color: var(--deep-charcoal); margin-bottom: 0.2rem;
  }
  .service-link-box p { font-size: 0.8rem; color: var(--warm-gray); }

  .cta-inner {
    display: flex; align-items: center; justify-content: space-between;
    background-color: var(--sand); border-radius: 16px; padding: 2.5rem;
  }
  .cta-text h2 { font-size: 1.5rem; font-weight: 700; color: var(--deep-charcoal); margin-bottom: 0.25rem; }
  .cta-text p { font-size: 0.9rem; color: var(--warm-gray); }

  @media (max-width: 768px) {
    .article-wrap { margin-top: -2rem; padding: 2rem 1.25rem; }
    .service-link-box { flex-direction: column; gap: 1rem; text-align: center; }
    .cta-inner { flex-direction: column; text-align: center; gap: 1.5rem; padding: 2rem 1.5rem; }
  }
</style>
